FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-secure-random-string-in-production
DATABASE_URL=sqlite:///instance/shikhapay.db

# Email Configuration (for payslip delivery)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-university-email@gmail.com
MAIL_PASSWORD=your-app-password-here

# Security Settings
BCRYPT_LOG_ROUNDS=12
SESSION_COOKIE_SECURE=True
REMEMBER_COOKIE_SECURE=True

# Feature Flags
ENABLE_AI_MODULE=True
ENABLE_PWA=True
ENABLE_GUARDIAN_SECURITY=True

# API Keys (Production - Get from respective authorities)
NBR_API_KEY=your-nbr-api-key-here
SONALI_BANK_API_KEY=your-bank-api-key-here
UGC_API_ENDPOINT=https://api.ugc.gov.bd/sync
NID_API_KEY=your-nid-api-key-here

# Admin Contact
ADMIN_EMAIL=admin@du.ac.bd
SUPPORT_EMAIL=support@shikhapay.edu.bd

# National Deployment Settings
UNIVERSITY_ID=DU001
REGIONAL_HUB=Dhaka
